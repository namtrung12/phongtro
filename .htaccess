DirectoryIndex index.php
RewriteEngine On

AddType application/manifest+json .webmanifest

# Không public file cấu hình, mã nguồn nội bộ và file database khi đặt toàn bộ
# dự án trong public_html.
RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L,NC]
RewriteRule ^(?:\.env|\.env\..*|database\.sql)$ - [F,L,NC]
RewriteRule ^(?:app|backend|frontend|views)(?:/|$) - [F,L,NC]
RewriteRule ^storage/(?!uploads/).*$ - [F,L,NC]
RewriteRule ^storage/uploads/.*\.(?:php[0-9]?|phtml|phar|cgi|pl|sh)$ - [F,L,NC]

# Giữ nguyên file tĩnh public như ảnh, logo, CSS/JS và storage/uploads.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Map path /abc sang index.php?route=abc (ví dụ /payment-webhook)
RewriteRule ^([^?]*)$ index.php?route=$1 [QSA,L]
